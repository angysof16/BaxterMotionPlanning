<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="baxter_gazebo">

  <!-- Include pure robot -->
  <xacro:include filename="$(find baxter_description)/urdf/robots/baxter.urdf.xacro" />

  <!-- Include gazebo sensors -->
  <xacro:include filename="$(find gazebo_baxter)/urdf/sensors/imu_gazebo.urdf.xacro" />
  <xacro:include filename="$(find gazebo_baxter)/urdf/sensors/lidar_gazebo.urdf.xacro" />
  <xacro:include filename="$(find gazebo_baxter)/urdf/sensors/camera_color_gazebo.urdf.xacro" />
  <xacro:include filename="$(find gazebo_baxter)/urdf/sensors/camera_rgbd_gazebo.urdf.xacro" />

  <xacro:macro name="baxter_gazebo" params="name use_sensors:=true">
    <!-- Instantiate base robot -->
    <xacro:baxter name="${name}" use_sensors="${use_sensors}" />

    <!-- Add Gazebo-specific sensor tags ONLY if sensors are enabled -->
    <xacro:if value="${use_sensors}">
      <!-- Reference the sensor links created by baxter.urdf.xacro -->
      <xacro:imu_gazebo frame="imu_link" topic_name="imu" sensor_name="imu_sensor" />
      <xacro:lidar_gazebo frame="lidar_link" topic_name="scan" sensor_name="lidar_sensor" />
      <xacro:camera_color_gazebo frame="camera_link" topic_name="camera/image_raw"
        sensor_name="camera_sensor" />
    </xacro:if>

    <!-- ROS2 CONTROL CONFIGURATION -->
    <ros2_control name="BaxterGazeboSystem" type="system">
      <hardware>
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </hardware>

      <!-- HEAD JOINT -->
      <joint name="torso_head">
        <command_interface name="position">
          <param name="min">-0.7854</param>
          <param name="max">0.7854</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <!-- RIGHT ARM JOINTS -->
      <joint name="torso_right_upper_shoulder">
        <command_interface name="position">
          <param name="min">-0.89</param>
          <param name="max">1.5708</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="right_upper_shoulder_lower_shoulder">
        <command_interface name="position">
          <param name="min">-1.0472</param>
          <param name="max">0.5236</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="right_lower_shoulder_upper_elbow">
        <command_interface name="position">
          <param name="min">-1.5708</param>
          <param name="max">1.5708</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="right_upper_elbow_lower_elbow">
        <command_interface name="position">
          <param name="min">-1.5708</param>
          <param name="max">0.0524</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="right_lower_elbow_upper_forearm">
        <command_interface name="position">
          <param name="min">-3.0543</param>
          <param name="max">3.0543</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="right_upper_forearm_lower_forearm">
        <command_interface name="position">
          <param name="min">-1.5708</param>
          <param name="max">1.5708</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="right_lower_forearm_wrist">
        <command_interface name="position">
          <param name="min">-3.0543</param>
          <param name="max">3.0543</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <!-- LEFT ARM JOINTS -->
      <joint name="torso_left_upper_shoulder">
        <command_interface name="position">
          <param name="min">-1.5708</param>
          <param name="max">0.89</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="left_upper_shoulder_lower_shoulder">
        <command_interface name="position">
          <param name="min">-0.5236</param>
          <param name="max">1.0472</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="left_lower_shoulder_upper_elbow">
        <command_interface name="position">
          <param name="min">-1.5708</param>
          <param name="max">1.5708</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="left_upper_elbow_lower_elbow">
        <command_interface name="position">
          <param name="min">-0.0524</param>
          <param name="max">1.5708</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="left_lower_elbow_upper_forearm">
        <command_interface name="position">
          <param name="min">-3.0543</param>
          <param name="max">3.0543</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="left_upper_forearm_lower_forearm">
        <command_interface name="position">
          <param name="min">-1.5708</param>
          <param name="max">1.5708</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="left_lower_forearm_wrist">
        <command_interface name="position">
          <param name="min">-3.0543</param>
          <param name="max">3.0543</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <!-- GRIPPER JOINTS (optional - for future gripper control) -->
      <joint name="r_gripper_l_finger_joint">
        <command_interface name="position">
          <param name="min">0.0</param>
          <param name="max">0.020833</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="l_gripper_l_finger_joint">
        <command_interface name="position">
          <param name="min">0.0</param>
          <param name="max">0.020833</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

    </ros2_control>

    <!-- GAZEBO ROS2 CONTROL PLUGIN -->
    <gazebo>
      <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
        <parameters>$(find gazebo_baxter)/config/controllers.yaml</parameters>
      </plugin>
    </gazebo>

    <!-- Joint State Publisher Plugin -->
    <gazebo>
      <plugin filename="gz-sim-joint-state-publisher-system"
        name="gz::sim::systems::JointStatePublisher">
      </plugin>
    </gazebo>

  </xacro:macro>

  <!-- Instantiate the macro -->
  <xacro:baxter_gazebo name="baxter" use_sensors="true" />
</robot>