    </link>

    <!-- Left grippers -->
    <link name="left_grippers">
      <visual>
        <origin rpy="0 3.1416 0" xyz="0 0 0" />
        <geometry>
          <mesh filename="package://baxter_description/meshes/grippers/GRIPPER.STL" />
