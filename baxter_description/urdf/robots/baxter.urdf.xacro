<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="baxter">

  <!-- Include sensors -->
  <xacro:include filename="$(find baxter_description)/urdf/sensors/imu.urdf.xacro" />
  <xacro:include filename="$(find baxter_description)/urdf/sensors/lidar.urdf.xacro" />
  <xacro:include filename="$(find baxter_description)/urdf/sensors/camera_color.urdf.xacro" />
  <xacro:include filename="$(find baxter_description)/urdf/sensors/camera_rgbd.urdf.xacro" />

  <!-- Macro definition -->
  <xacro:macro name="baxter" params="name use_sensors:=true">

    <link name="world" />

    <!-- Pedestal -->
    <link name="base_link">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0" />
        <geometry>
          <mesh filename="package://baxter_description/meshes/base/PEDESTAL.STL" scale="1 1 1" />
        </geometry>
        <material name="darkgray">
          <color rgba=".2 .2 .2 1" />
        </material>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0" />
        <geometry>
          <mesh
            filename="package://baxter_description/meshes/base/pedestal_link_collision.STL"
            scale="1 1 1" />
        </geometry>
      </collision>
      <inertial>
        <origin rpy="0 0 0" xyz="0 0 0" />
        <mass value="60.86397744" />
        <inertia ixx="5.0635929" ixy="0.00103417" ixz="0.80199628" iyy="6.08689388"
          iyz="0.00105311"
          izz="4.96191932" />
      </inertial>
    </link>


    <!-- Head -->
    <link name="head">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0" />
        <geometry>
          <mesh filename="package://baxter_description/meshes/head/H0.STL" />
        </geometry>
        <material name="darkgray">
          <color rgba=".2 .2 .2 1" />
        </material>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0" />
        <geometry>
          <mesh filename="package://baxter_description/meshes/head/H0.STL" />
        </geometry>
      </collision>
      <inertial>
        <origin rpy="0 0 0" xyz="0 0 0" />
        <mass value="1.5" />
        <inertia ixx="0.004641" ixy="0.000159" ixz="0.000242" iyy="0.003295" iyz="-0.001324"
          izz="0.003415" />
      </inertial>
    </link>

    <link name="screen">
      <visual>
        <origin rpy="1.57079632679 0 0" xyz="0 0 0" />
        <geometry>
          <mesh filename="package://baxter_description/meshes/head/H1.STL" />
        </geometry>
        <material name="darkred">
          <color rgba=".5 .1 .1 1" />
        </material>
      </visual>
      <collision>
        <origin rpy="1.57079632679 0 0" xyz="0 0 0" />
        <geometry>
          <mesh filename="package://baxter_description/meshes/head/H1.STL" />
        </geometry>
      </collision>
      <inertial>
        <origin rpy="1.57079632679 0 0" xyz="0 0 0" />
        <mass value="1" />
        <inertia ixx="0.004006" ixy="0.000230" ixz="0.000002" iyy="0.002800" iyz="0.000029"
          izz="0.001509" />
      </inertial>
    </link>

    <link name="hat">
      <visual>
        <origin rpy="0 0 1.5708" xyz="0 0 -.08" />
        <geometry>
          <mesh filename="package://baxter_description/meshes/head/HAT.STL" scale=".01 .01 .01" />
        </geometry>
        <material name="hat">
          <color rgba=".875 .84 .757 1" />
        </material>
      </visual>
      <collision>
        <origin rpy="0 0 1.5708" xyz="0 0 -.08" />
        <geometry>
          <mesh filename="package://baxter_description/meshes/head/HAT.STL" scale=".01 .01 .01" />
        </geometry>
      </collision>
      <inertial>
        <origin rpy="0 0 1.5708" xyz="0 0 -.08" />
        <mass value=".3" />
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
      </inertial>
    </link>

    <!-- Torso -->
    <link name="torso">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0" />
        <geometry>
          <mesh filename="package://baxter_description/meshes/torso/base_link.STL" />
        </geometry>
        <material name="darkgray">
          <color rgba=".2 .2 .2 1" />
        </material>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0" />
        <geometry>
          <mesh filename="package://baxter_description/meshes/torso/base_link_collision.STL" />
        </geometry>
      </collision>
      <inertial>
        <mass value="35.336455" />
        <inertia ixx="1.849155" ixy="-0.000354" ixz="-0.154188" iyy="1.662671"
          iyz="0.003292"
          izz="0.802239" />
      </inertial>
    </link>


    <!-- ====== LEFT ARM LINKS ====== -->

    <!-- Left upper shoulder -->
    <link name="left_upper_shoulder">
      <visual>
        <origin rpy="0 0 1.5708" xyz="0 0 0" />
        <geometry>
          <mesh filename="package://baxter_description/meshes/upper_shoulder/S0.STL" />
        </geometry>
        <material name="darkgray">
          <color rgba=".2 .2 .2 1" />
        </material>
      </visual>
      <collision>
        <origin rpy="0 0 1.5708" xyz="0 0 0" />
        <geometry>
          <!--cylinder
          length="0.2722" radius="0.06" /-->
          <mesh filename="package://baxter_description/meshes/upper_shoulder/S0.STL" />
        </geometry>
      </collision>
      <inertial>
        <origin rpy="0 0 0" xyz="0.01783 0.00086 0.19127" />
        <mass value="5.70044" />
        <inertia ixx="0.04709102262" ixy="0.00012787556" ixz="0.00614870039"
          iyy="0.03766976455"
          iyz="0.00078086899" izz="0.03595988478" />
      </inertial>
    </link>

    <!-- Left lower shoulder -->
    <link name="left_lower_shoulder">
      <visual>
        <origin rpy="1.5708 0 1.5708" xyz="0 0 0" />
