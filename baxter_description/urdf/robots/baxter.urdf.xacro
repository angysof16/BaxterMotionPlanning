    <!-- TODO: Add joints/links for baxter (arms, wheels, etc.) -->
    <!-- ====== JOINTS ====== -->
    <joint name="world_to_base" type="fixed">
      <parent link="world" />
      <child link="base_link" />
      <origin xyz="0 0 .924" rpy="0 0 0" />
    </joint>

    <!-- head - screen -->
    <joint name="head_screen" type="fixed">
      <origin rpy="0 0 0" xyz=".07 0 0" />
      <parent link="head" />
      <child link="screen" />
    </joint>

    <!-- pedestal - torso -->
    <joint name="pedestal_torso" type="fixed">
      <parent link="base_link" />
      <child link="torso" />
      <origin xyz="0 0 0" rpy="0 0 0" />
    </joint>

    <!-- torso - head -->
    <joint name="torso_head" type="revolute">
      <parent link="torso" />
      <child link="head" />
      <origin xyz=".062 0 .6875" rpy="0 0 0" />
      <axis xyz="0 0 1" />
      <limit lower="-0.7854" upper="0.7854" effort="50" velocity="1.5" />
    </joint>

    <!-- head - hat-->
    <joint name="head_hat" type="fixed">
      <parent link="head" />
      <child link="hat" />
      <!-- <origin rpy="0 0 0" xyz=".063 0 .39" /> -->
      <origin rpy="0 0 0" xyz="0 0 .18" />
    </joint>


    <!-- ========== LEFT ARM ========== -->

    <!-- torso - left upper shoulder -->
    <joint name="torso_left_upper_shoulder" type="revolute">
